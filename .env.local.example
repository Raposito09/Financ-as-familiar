# ============================================================
# Finança Familiar — variáveis de ambiente
# Copie este arquivo para .env.local e preencha com os valores reais.
# Nunca commite .env.local no git.
# ============================================================

# --- Supabase (obrigatório, V1) -----------------------------
# Obter em: https://supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Resend — email semanal (V2) -----------------------------
# Obter em: https://resend.com → API Keys
# Free tier: 3.000 emails/mês
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remetente; precisa ser um domínio verificado no Resend ou usar o sandbox
RESEND_FROM="Finança Familiar <onboarding@resend.dev>"

# --- Cron (V2) -----------------------------------------------
# Token livre, gerado por você. Usado para autenticar chamadas
# externas a /api/email/weekly?all=true e similares.
# Exemplo: openssl rand -hex 32
CRON_SECRET=cole-um-token-forte-aqui

# --- Gemini AI (V3) -----------------------------------------
# Obter em: https://aistudio.google.com/apikey
# Free tier: ~10 req/min — suficiente para uso familiar
GEMINI_API_KEY=AIzaSy97d8803e-716b-479f-aaaf-5864639ea918
# Opcional — modelo. Default: gemini-2.5-flash (recomendado, free tier)
# Outras opções: gemini-2.5-pro (mais caro), gemini-2.0-flash (mais barato)
GEMINI_MODEL=gemini-2.5-flash
